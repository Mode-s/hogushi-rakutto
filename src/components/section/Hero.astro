---
import SectionDeco from '../common/SectionDeco.astro';
import { getImage } from 'astro:assets';

import pcHero from '../../assets/images/pc-hero.png';
import tabHero from '../../assets/images/tab-hero.png';
import spHero from '../../assets/images/sp-hero.png';

const pc = await getImage({ src: pcHero, format: 'webp' });
const tab = await getImage({ src: tabHero, format: 'webp' });
const sp = await getImage({ src: spHero, format: 'webp' });
---
<section class="hero">
  <picture class="hero-picture">
    <source media="(max-width: 500px)" srcset={sp.src} />
    <source media="(max-width: 768px)" srcset={tab.src} />
    <img
      src={pc.src}
      alt=""
      data-hero-image
    />
  </picture>
  <div class="hero-copy">
    <span class="hero-glow" aria-hidden="true"></span>
    <h2 class="hero-text">
      心も身体も<span class="hero-em">ラク</span>に
    </h2>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;


  // ――――――――――――――――――――――――――――――――――― hero
  .hero {
    position: relative;
    display: flex; 
    align-items: center; 
    justify-content: center; 
    width: 100%;
    height: 100dvh;
    overflow: hidden;
  }
  // ――――――――――――――――――――――――――――――――――― hero-picture
  .hero-picture {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.6;
    mix-blend-mode: multiply;
    overflow: hidden;
  }

  .hero-picture img {
    will-change: transform;
  }

  .hero-copy {
    position: absolute;
    z-index: 2;                 // 画像(z-index:1)より前面
    display: flex;
    align-items: center;
    justify-content: center;
    left: 20%;
    top: 70%;                      // 画面の高さの70%地点（やや下）
    transform: translate(-50%, -50%);  // 自分の中心をその点に合わせる
  }

  .hero-glow {
    position: absolute;
    z-index: -1;                // テキストの背面に
    width: 120%;
    aspect-ratio: 1 / 1;
    background:
      radial-gradient(
        closest-side,
        rgba($color-cta, 0.9) 0%,
        rgba($color-cta, 0.5) 45%,
        rgba($color-cta, 0) 75%
      );
    filter: blur(30px);         // ふんわり感の主役
    pointer-events: none;
  }

  .hero-text {
    font-size: 1.5rem;
    letter-spacing: 0.15em;
    line-height: 1.6;
    text-align: center;
    // 文字自体にもうっすら光をまとわせる
    text-shadow: 0 0 18px rgba(#fff, 0.7);
  }

  .hero-em {
    font-size: 1.5em;           // 周囲より大きく
    color: #d98a00;             // cta系の濃い色でアクセント
    text-shadow: 0 0 24px rgba($color-cta, 0.9);
  }

  //―――――――――――――――――――――――――――――――――――――― ブレークポイント / タブレット
  @include tb {
    .hero-copy {
      left: 40%;
      top: 70%;  
    }
    .hero-text {
      font-size: 1rem;
    }
  }

  //―――――――――――――――――――――――――――――――――――――― ブレークポイント / スマホ
  @include sp {
    
  }
</style>